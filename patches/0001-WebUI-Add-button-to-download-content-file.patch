-    const torrentFilesTable = window.qBittorrent.TorrentContent.init("torrentFilesTableDiv", window.qBittorrent.DynamicTable.TorrentFilesTable, onFilePriorityChanged, onFileRenameHandler);
+    const singleContentFileDownload = (hash, node) => {
+        const path = node.path;
+        
+        const url = new URL("api/v2/torrents/downloadContentFile", window.location);
+        url.search = new URLSearchParams({ hash, path });
+        const link = document.createElement("a");
+        link.href = url.toString();
+        link.download = node.name;
+        link.click();
+        link.remove();
+    };
+
+    const onContentFileDownloadHandler = (selectedNodes) => {
+        for (const node of selectedNodes) {
+            if (!node.isFolder) {
+                singleContentFileDownload(current_hash, node);
+            }
+        }
+    };
+
+    const torrentFilesTable = window.qBittorrent.TorrentContent.init("torrentFilesTableDiv", window.qBittorrent.DynamicTable.TorrentFilesTable, onFilePriorityChanged, onFileRenameHandler, onContentFileDownloadHandler);
 
